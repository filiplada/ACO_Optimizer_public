<Window x:Class="ACO_Optimizer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ACO_Optimizer.Views"
        xmlns:vm="clr-namespace:ACO_Optimizer.ViewModels"
        xmlns:mapsui="clr-namespace:Mapsui.UI.Wpf;assembly=Mapsui.UI.Wpf"
        xmlns:conv="clr-namespace:ACO_Optimizer.Converters"
        mc:Ignorable="d"
        Title="ACO Optymalizacja"
        Height="750" Width="1200"
        xml:lang="pl-PL"
        FontFamily="Segoe UI">
    <Window.Resources>
        <conv:RoundToIntConverter x:Key="RoundToInt" />
        <conv:GreaterThanZeroToVisibilityConverter x:Key="GtZeroVisibility" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:NotNullToVisibilityConverter x:Key="NotNullToVisibility" />
    </Window.Resources>
    
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="240" />
            <RowDefinition Height="*" />
            </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions >
                <ColumnDefinition Width="400" />
                <ColumnDefinition Width="400" />
                <ColumnDefinition Width="400" />
            </Grid.ColumnDefinitions>

            <StackPanel Margin="20" Grid.Column="0">
                <TextBlock Text="Parametry ACO" FontWeight="Bold" FontSize="16" />
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Liczba mrówek:" Width="120" />
                    <TextBox Text="{Binding Parameters.NumberOfAnts}" Width="100" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Iteracje:" Width="120" />
                    <TextBox Text="{Binding Parameters.Iterations}" Width="100" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="Alpha (wpływ feromonu):" Width="160" />
                    <TextBox Text="{Binding Parameters.Alpha}" Width="100" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Beta (wpływ heurystyki):" Width="160" />
                    <TextBox Text="{Binding Parameters.Beta}" Width="100" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Wskaźnik parowania:" Width="160" />
                    <TextBox Text="{Binding Parameters.EvaporationRate}" Width="100" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Początkowy feromon:" Width="160" />
                    <TextBox Text="{Binding Parameters.InitialPheromone}" Width="100" />
                </StackPanel>
            </StackPanel>

            <StackPanel Margin="20" Grid.Column="1">
                <TextBlock Text="Parametry Podróży" FontWeight="Bold" FontSize="16" />

                <TextBlock Text="Punkt Startowy:" Margin="0,8,0,0"/>
                <ComboBox Name="startStations"
                          ItemsSource="{Binding Stations}"
                          DisplayMemberPath="Name"
                          SelectedItem="{Binding Parameters.StartingStation, Mode=TwoWay}"
                          Width="200"
                          Margin="0,8,0,0"/>

                <TextBlock Text="Punkt Docelowy:" Margin="0,8,0,0"/>
                <ComboBox Name="destinationStations"
                          ItemsSource="{Binding Stations}"
                          DisplayMemberPath="Name"
                          SelectedItem="{Binding Parameters.DestinationStation, Mode=TwoWay}"
                          Width="200"
                          Margin="0,8,0,0"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                    <TextBlock Text="Symulacja równoległa"
                               VerticalAlignment="Center"
                               ToolTip="Włącz przetwarzanie równoległe mrówek dla szybszych obliczeń" />
                    <CheckBox x:Name="ParallelSimulationCheckBox"
                              IsChecked="{Binding Parameters.EnableParallelSimulation, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0" />
                </StackPanel>

            </StackPanel>

            <StackPanel Margin="20" Grid.Column="2">
                <TextBlock Text="Dodatkowe Ograniczenia" FontWeight="Bold" FontSize="16" />
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Pojemność baterii (kWh)" Width="220" />
                    <TextBox Text="{Binding Parameters.BatteryCapacity}" Width="100" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Początkowy stan baterii (kWh):" Width="220" />
                    <TextBox Text="{Binding Parameters.InitialBattery}" Width="100" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="Konsumpcja (kWh/km przy 90km/h):" Width="220" />
                    <TextBox Text="{Binding Parameters.ConsumptionPerKm}" Width="100" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Tylko ładowarki z cennikiem?:" Width="220" />
                    <CheckBox x:Name="ShowPricedCheckBox"
                              IsChecked="{Binding Parameters.OnlyPricedChargers, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              ToolTip="Odznacz aby brać pod uwagę nie wycenione" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Typ ładowarki:" />
                    <ComboBox Name="chargerType"
                          ItemsSource="{Binding ChargerTypes}"
                          SelectedItem="{Binding Parameters.ChargerType, Mode=TwoWay}"
                          Width="250"
                          Margin="0,8,0,0"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions >
                <ColumnDefinition Width="400" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Margin="20" Grid.Column="0">
                <Button Content="Uruchom ACO" Command="{Binding RunACOCommand}" Margin="10" />

                <TextBlock Text="Najlepsza trasa:" FontWeight="Bold" FontSize="16" Margin="10" 
                           Visibility="{Binding BestRoute, Converter={StaticResource NotNullToVisibility}}" />

                <!-- Scrollable area for BestRoute stations -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300" Margin="0,0,0,8"
                              Visibility="{Binding BestRoute, Converter={StaticResource NotNullToVisibility}}">
                    <ItemsControl ItemsSource="{Binding BestRoute.Stations}" AlternationCount="100">    
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                    
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock x:Name="BatteryLabel" Text="Prognozowany Stan Baterii (Wjazd):" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding EnergyOnArrivalKwh, Converter={StaticResource RoundToInt}, StringFormat='{}{0} kWh'}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="Prognozowany Stan Baterii (Wyjazd):" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding EnergyOnDepartureKwh, Converter={StaticResource RoundToInt}, StringFormat='{}{0} kWh'}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0"
                                                Visibility="{Binding ChargingTimeMin, Converter={StaticResource GtZeroVisibility}}">
                                        <TextBlock Text="Prognozowany czas ładowania:" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding ChargingTimeMin, Converter={StaticResource RoundToInt}, StringFormat='{}{0} min'}" VerticalAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0"
                                                Visibility="{Binding WasChargedHere, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Prognozowany czas w kolejce:" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding QueueTimeMin, Converter={StaticResource RoundToInt}, StringFormat='{}{0} min'}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                                
                                <DataTemplate.Triggers>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="0" >
                                        <Setter TargetName="BatteryLabel" Property="Text" Value="Początkowy Stan Baterii:" />
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Rounded total distance (full km) -->
                <TextBlock Text="{Binding BestRoute.TotalDistance, Converter={StaticResource RoundToInt}, StringFormat='Całkowity Dystans: {0} km'}" FontWeight="Bold" FontSize="16" 
                           Visibility="{Binding BestRoute, Converter={StaticResource NotNullToVisibility}}" />

                <!-- Rounded travel time (full minutes) -->
                <TextBlock Text="{Binding BestRoute.TotalTime, Converter={StaticResource RoundToInt}, StringFormat='Czas Podróży: {0} minut'}" FontWeight="Bold" FontSize="16" 
                           Visibility="{Binding BestRoute, Converter={StaticResource NotNullToVisibility}}" />

                <!-- Rounded calculation time (milliseconds) -->
                <TextBlock Text="{Binding TimeInTicks, Converter={StaticResource RoundToInt}, StringFormat='Czas Kalkulacji: {0} ms'}" FontWeight="Bold" FontSize="16" 
                           Visibility="{Binding BestRoute, Converter={StaticResource NotNullToVisibility}}" />

                <TextBlock Text="Nie znaleziono trasy dla parametrów"
                           FontWeight="Bold"
                           Foreground="Red"
                           FontSize="16"
                           Visibility="{Binding IsPathUnachievable, Converter={StaticResource BoolToVis}}" />
            </StackPanel>

            <mapsui:MapControl x:Name="MapControl" Grid.Column="1"/>

        </Grid>
    </Grid>
</Window>

